{
  "compilerOptions": {
    "target": "ESNext", // Target ES6 or higher
    "module": "ESNext", // Module format
    "declaration": true, // Generates .d.ts files
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true, // Enable all strict type-checking options
    "esModuleInterop": true, // For compatibility with ES6 modules
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "declarationMap": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "tests"
  ]
}